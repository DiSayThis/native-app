{
  "expo": {
    "name": "Studmart",
    "slug": "studmart-native-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./shared/assets/image/icon-1024.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./shared/assets/image/splash-screen-portrait.png",
      "resizeMode": "cover"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./shared/assets/image/adaptive-icon-foreground.png",
        "monochromeImage": "./shared/assets/image/adaptive-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./shared/assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./shared/assets/fonts/Mulish/Mulish-Regular.ttf",
            "./shared/assets/fonts/Nunito/Nunito-Regular.ttf"
          ],
          "android": {
            "fonts": [
              {
                "fontFamily": "Mulish",
                "fontDefinitions": [
                  {
                    "path": "./shared/assets/fonts/Mulish/Mulish-Light.ttf",
                    "weight": 300
                  },
                  {
                    "path": "./shared/assets/fonts/Mulish/Mulish-Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "./shared/assets/fonts/Mulish/Mulish-Medium.ttf",
                    "weight": 500
                  },
                  {
                    "path": "./shared/assets/fonts/Mulish/Mulish-SemiBold.ttf",
                    "weight": 600
                  },
                  {
                    "path": "./shared/assets/fonts/Mulish/Mulish-Bold.ttf",
                    "weight": 700
                  },
                  {
                    "path": "./shared/assets/fonts/Mulish/Mulish-BoldItalic.ttf",
                    "weight": 700,
                    "style": "italic"
                  },
                  {
                    "path": "./shared/assets/fonts/Mulish/Mulish-Bold.ttf",
                    "weight": 700
                  }
                ]
              },
              {
                "fontFamily": "NunitoSans",
                "fontDefinitions": [
                  {
                    "path": "./shared/assets/fonts/Nunito/Nunito-Light.ttf",
                    "weight": 300
                  },
                  {
                    "path": "./shared/assets/fonts/Nunito/Nunito-Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "./shared/assets/fonts/Nunito/Nunito-Medium.ttf",
                    "weight": 500
                  },
                  {
                    "path": "./shared/assets/fonts/Nunito/Nunito-SemiBold.ttf",
                    "weight": 600
                  },
                  {
                    "path": "./shared/assets/fonts/Nunito/Nunito-Bold.ttf",
                    "weight": 700
                  },
                  {
                    "path": "./shared/assets/fonts/Nunito/Nunito-BoldItalic.ttf",
                    "weight": 700,
                    "style": "italic"
                  },
                  {
                    "path": "./shared/assets/fonts/Nunito/Nunito-Bold.ttf",
                    "weight": 700
                  }
                ]
              }
            ]
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "scheme": "studmart-native-app-scheme"
  }
}
