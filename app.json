{
	"expo": {
		"name": "Студмарт",
		"slug": "studmart-native-app",
		"version": "1.0.0",
		"orientation": "default",
		"icon": "./shared/assets/image/AppIcon.png",
		"userInterfaceStyle": "automatic",
		"splash": {
			"image": "./shared/assets/image/splash-logo.png",
			"resizeMode": "contain",
			"backgroundColor": "#9AEF58",
			"dark": {
				"image": "./shared/assets/image/splash-logo.png",
				"backgroundColor": "#9AEF58"
			}
		},
		"ios": {
			"supportsTablet": true,
			"bundleIdentifier": "studmart.app",
			"associatedDomains": ["applinks:studmart.ru"]
		},
		"android": {
			"package": "studmart.app",
			"adaptiveIcon": {
				"foregroundImage": "./shared/assets/image/adaptive-icon-foreground.png",
				"backgroundImage": "./shared/assets/image/adaptive-icon-background.png",
				"backgroundColor": "#9AEF58",
				"monochromeImage": "./shared/assets/image/adaptive-icon-monochrome.png"
			},
			"softwareKeyboardLayoutMode": "resize",
			"predictiveBackGestureEnabled": false,
			"intentFilters": [
				{
					"action": "VIEW",
					"autoVerify": true,
					"data": [
						{
							"scheme": "https",
							"host": "studmart.ru",
							"path": "/"
						},
						{
							"scheme": "https",
							"host": "studmart.ru",
							"path": "/registration"
						},
						{
							"scheme": "https",
							"host": "studmart.ru",
							"pathPrefix": "/login"
						},
						{
							"scheme": "https",
							"host": "studmart.ru",
							"pathPrefix": "/partner-offer"
						},
						{
							"scheme": "https",
							"host": "studmart.ru",
							"pathPrefix": "/student-personal-account"
						},
						{
							"scheme": "https",
							"host": "studmart.ru",
							"pathPrefix": "/privacy-policy"
						},
						{
							"scheme": "https",
							"host": "studmart.ru",
							"path": "/files/Пользовательское соглашение.pdf"
						},
						{
							"scheme": "https",
							"host": "studmart.ru",
							"path": "/files/Политика конфиденциальности.pdf"
						}
					],
					"category": ["BROWSABLE", "DEFAULT"]
				}
			]
		},
		"web": {
			"favicon": "./shared/assets/favicon.png"
		},
		"plugins": [
			"expo-router",
			[
				"expo-notifications",
				{
					"icon": "./shared/assets/image/notification-icon-96.png",
					"color": "#9AEF58",
					"defaultChannel": "default"
				}
			],
			[
				"expo-font",
				{
					"fonts": [
						"./shared/assets/fonts/Mulish/Mulish-Regular.ttf",
						"./shared/assets/fonts/Nunito/Nunito-Regular.ttf"
					]
				}
			],
			"@react-native-community/datetimepicker",
			"expo-image",
			"expo-web-browser"
		],
		"scheme": "studmart-native-app-scheme",
		"extra": {
			"router": {},
			"eas": {
				"projectId": "adc5220e-75ca-4c7a-a703-ac670b6594d7"
			}
		}
	}
}
